#!/bin/bash

APP=$1

mkdir -p $APP.sota
cd $APP.sota

cat > manifest.json <<EOF
{
  "name": "$APP",
  "version": "1.0",
  "description": "$APP package",
  "type": "app",
  "install": "install.sh",
  "uninstall": "uninstall.sh"
}
EOF

touch install.sh uninstall.sh
chmod +x install.sh uninstall.sh

echo "Package $APP.sota created"
